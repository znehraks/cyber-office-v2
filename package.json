{
  "name": "cyber-office-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint:shell": "bash -n ./scripts/*.sh",
    "test": "node --test test/*.runtime.test.js",
    "doctor": "node ./src/cli.js doctor",
    "start": "node ./src/cli.js start",
    "stop": "node ./src/cli.js stop",
    "ps": "node ./src/cli.js ps",
    "attach": "node ./src/cli.js attach",
    "legacy:cleanup": "bash ./scripts/cleanup-legacy-launchd.sh",
    "status": "node ./src/cli.js status",
    "reset-runtime": "bash ./scripts/reset-runtime-state.sh",
    "smoke": "CLAUDE_BIN=node CO_SMOKE_EXTRA_ARGS_JSON='[\"./test/fixtures/fake-claude-success.js\"]' node ./src/cli.js smoke",
    "ci": "npm run lint:shell && npm run reset-runtime && node ./src/cli.js init && node ./src/cli.js doctor && npm test && npm run reset-runtime && npm run smoke",
    "bot:ceo": "bash ./scripts/run-discord-ceo.sh",
    "bot:god": "bash ./scripts/run-discord-god.sh",
    "supervisor:daemon": "bash ./scripts/run-supervisor-daemon.sh"
  },
  "dependencies": {
    "discord.js": "^14.26.2"
  }
}
