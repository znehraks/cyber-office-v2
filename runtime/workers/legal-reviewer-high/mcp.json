{
  "mcpServers": {
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "korean-law": {
      "command": "korean-law-mcp",
      "env": {
        "LAW_OC": "YOUR_LAW_OC_KEY"
      }
    },
    "playwriter": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "playwriter"
      ]
    }
  }
}
